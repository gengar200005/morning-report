    {% if _ca_sector %}
    <div class="claude-card">
      <div class="claude-label">🗒 Claude · 섹터 로테이션</div>
      <div class="claude-body">{{ _ca_sector | safe }}</div>
    </div>
    {% endif %}
  </section>

  <hr class="decorative">

  <!-- ========== SECTION 4: ENTRY READINESS (NEW) ========== -->
  <section>
    <div class="section-header">
      <div class="section-num">04</div>
      <div class="section-title">
        <div class="eyebrow">Minervini · Top 5 Entry Readiness</div>
        <h2>Grade A · Top 5</h2>
      </div>
      <div class="section-meta">A:{{ data.minervini.counts.A }} B:{{ data.minervini.counts.B }} C:{{ data.minervini.counts.C }} D:{{ data.minervini.counts.D }}</div>
    </div>

    <p style="font-family: var(--sans); font-size: 12px; color: var(--ink-muted); margin-bottom: 18px; padding: 10px 14px; background: var(--bg); border-left: 3px solid var(--accent); line-height: 1.5;">
      <strong style="color: var(--ink);">판독 기준</strong> · 좌측(자동)은 스크리너로 검증된 트렌드 템플릿 조건, 우측(수동)은 차트에서 직접 확인해야 하는 Minervini 진입 트리거(VCP 수축·피벗 돌파·거래량 확장). <strong style="color: var(--ink);">우측 4개가 모두 확인되어야 실제 진입</strong>, 아니면 관망.
    </p>

    {% for stock in data.top5 %}
    <div class="readiness-card{% if stock.is_held %} held{% endif %}">
      <div class="readiness-header">
        <div class="rank">{{ stock.rank_roman }}</div>
        <div class="readiness-title">
          <div class="name">{{ stock.name | replace('&', '&amp;') }} <span class="ticker">{{ stock.code }} · {{ stock.signal_days }}일차</span>{% if stock.is_held %}<span class="held-tag">HELD</span>{% endif %}</div>
          <div class="meta">
            <span>MA50 {{ stock.ma50 | format_number }}</span>
            <span>MA150 {{ stock.ma150 | format_number }}</span>
            {% if stock.per < 0 %}
            <span>PBR {{ stock.pbr | format_number(2) }}×</span>
            {% else %}
            <span>PER {{ stock.per | format_number(1) }}×</span>
            {% endif %}
            <span>ROE {% if stock.roe >= 0 %}{{ stock.roe | format_pct_unsigned(1) }}{% else %}<span class="down">{{ stock.roe | format_pct_signed(1) }}</span>{% endif %}</span>
            <span>52W 고점 <span class="{{ 'up' if stock.pct_from_52w_high >= 0 else 'down' }}">{{ stock.pct_from_52w_high | format_pct_signed(1) }}</span></span>
          </div>
        </div>
        <div class="readiness-price">
          <div class="price">{{ stock.price | format_number }}</div>
          <div class="stop">손절 · {{ stock.stop_price | format_number }}</div>
          <div class="rs">RS {{ stock.rs }}</div>
        </div>
      </div>
      <div class="readiness-body">
        <div class="check-col auto-col">
          <div class="check-head"><span class="tag">AUTO</span><span class="label">Trend Template{% if loop.first %} (자동 검증){% endif %}</span></div>
          <ul class="check-list">
            <li><span class="check-mark">{{ '✓' if stock.core == stock.core_max else '✗' }}</span>코어 조건 8/8 <span class="check-val">100%</span></li>
            <li><span class="check-mark">{{ '✓' if stock.rs >= 70 else '✗' }}</span>RS ≥ 70 <span class="check-val">{{ stock.rs }}</span></li>
            <li><span class="check-mark">{{ stock.leading_check }}</span>주도 섹터 소속 <span class="check-val">{{ stock.leading_detail }}</span></li>
            <li><span class="check-mark">{{ '✓' if data.market_context.vix_ok and data.market_context.kospi_ma60_ok else '✗' }}</span>시장 게이트 통과 <span class="check-val">VIX+MA60</span></li>
          </ul>
        </div>
        <div class="check-col manual-col">
          <div class="check-head"><span class="tag">MANUAL</span><span class="label">{{ stock.trigger_label }}{% if loop.first %} (차트 확인){% endif %}</span></div>
          <ul class="check-list">
            {% if stock.is_held %}
            {% set _holding_matches = data.holdings | selectattr("code", "equalto", stock.code) | list %}
            {% set holding_match = _holding_matches[0] if _holding_matches else None %}
            <li><span class="check-mark">⚠</span>추매 가격 도달 <span class="check-val">{{ holding_match.add_threshold | format_number if holding_match else '차트 확인' }} 대기</span></li>
            <li><span class="check-mark">⚠</span>추매 시점 거래량 확장 <span class="check-val">차트 확인</span></li>
            <li><span class="check-mark">⚠</span>손절선 이탈 여부 <span class="check-val">{{ holding_match.stop_price | format_number if holding_match else stock.stop_price | format_number }} 유지</span></li>
            <li><span class="check-mark">⚠</span>시장 게이트 유지 <span class="check-val">매일 재확인</span></li>
            {% else %}
            <li><span class="check-mark">⚠</span>VCP 수축 2~6회 <span class="check-val">차트 확인</span></li>
            <li><span class="check-mark">⚠</span>피벗 포인트 돌파 <span class="check-val">52W {{ stock.pct_from_52w_high | format_pct_signed(1) }}</span></li>
            <li><span class="check-mark">⚠</span>돌파 시 거래량 ≥ ×1.3 <span class="check-val">차트 확인</span></li>
            <li><span class="check-mark">⚠</span>직전 수축기 거래량 고갈 <span class="check-val">차트 확인</span></li>
            {% endif %}
          </ul>
        </div>
      </div>
      <div class="readiness-footer">
        <span class="verdict-tag">{{ stock.verdict_tag }}</span>
        <span>{{ stock.verdict_text | safe }}</span>
      </div>
    </div>
    {% endfor %}

    {% set _ca_entry = (claude_analysis | default({})).get("entry") %}
    {% if _ca_entry %}
    <div class="claude-card">
      <div class="claude-label">🗒 Claude · A등급 Top 5 동향</div>
      <div class="claude-body">{{ _ca_entry | safe }}</div>
    </div>
    {% endif %}
  </section>

  <!-- ========== SECTION 4B: A-GRADE REMAINING ========== -->
  <section>
    <div class="section-header">
      <div class="section-num">04<span style="font-size: 22px;">·b</span></div>
      <div class="section-title">
        <div class="eyebrow">A-Grade · Complete Universe</div>
        <h2>Remaining {{ data.remaining_a | length }} Tickers</h2>
      </div>
      <div class="section-meta">SORTED BY RS</div>
    </div>

    <table class="agrade-table">
      <thead>
        <tr>
          <th>#</th><th>종목</th><th>코드</th>
          <th class="num">현재가</th><th class="num">RS</th>
          <th class="num">52W 고점</th><th class="num">일수</th>
          <th class="num">손절</th>
        </tr>
      </thead>
      <tbody>
        {% for stock in data.remaining_a %}
        <tr><td class="num">{{ stock.rank_num }}</td><td class="name">{{ stock.name | replace('&', '&amp;') }}</td><td>{{ stock.code }}</td><td class="num">{{ stock.price | format_number }}</td><td class="num"><span class="rs-bar {{ stock.rs_bar_class }}">{{ stock.rs }}</span></td><td class="num{% if stock.pct_from_52w_high < 0 %} down{% endif %}">{% if stock.pct_from_52w_high >= -0.5 %}<span class="nh-badge">NH</span>{% else %}{{ stock.pct_from_52w_high | format_pct_signed(1) }}{% endif %}</td><td class="num">{{ stock.signal_days }}D</td><td class="num down">{{ stock.stop_price | format_number }}</td></tr>
        {% endfor %}
      </tbody>
    </table>

    <div style="margin-top: 18px; padding: 12px 16px; background: var(--bg); font-family: var(--mono); font-size: 11px; color: var(--ink-muted); border-left: 2px solid var(--ink-muted);">
      <strong style="color: var(--ink);">C-GRADE ({{ data.minervini.counts.C }}):</strong> {{ data.minervini.grade_c | join(' · ') }}
      <span style="margin: 0 10px; color: var(--ink-faint);">|</span>
      <strong style="color: var(--ink);">B-GRADE:</strong> {{ data.minervini.counts.B }}종목 (노션 DB 참조)
    </div>

    {% set _ca_agrade = (claude_analysis | default({})).get("agrade") %}
    {% if _ca_agrade %}
    <div class="claude-card">
      <div class="claude-label">🗒 Claude · A등급 유니버스</div>
      <div class="claude-body">{{ _ca_agrade | safe }}</div>
    </div>
    {% endif %}
  </section>

  <!-- ========== SECTION 5: PORTFOLIO ========== -->
  <section>
    <div class="section-header">
      <div class="section-num">05</div>
      <div class="section-title">
        <div class="eyebrow">Portfolio · 1 Position</div>
        <h2>Holdings</h2>
      </div>
      <div class="section-meta">HOLD</div>
    </div>

    {% for h in data.holdings %}
    <div class="portfolio-main">
      <div>
        <div class="portfolio-header">
          <div class="portfolio-name">{{ h.name }} <span class="ticker" style="font-family: var(--mono); font-size: 12px; color: var(--ink-faint);">{{ h.code }}</span></div>
          <div class="portfolio-status">HOLD</div>
        </div>

        <div class="portfolio-grid">
          <div class="pg-label">매수가</div>
          <div class="pg-value">{{ h.buy_price | format_number }} 원</div>
          <div class="pg-label">현재가</div>
          <div class="pg-value big">{{ h.current_price | format_number }} 원 <span class="{{ 'pill-up' if h.change_pct >= 0 else 'pill-down' }}" style="margin-left: 6px; font-size: 12px; vertical-align: middle;">{{ h.change_pct | format_change_arrow }} {{ h.change_pct | format_pct_signed(2) }}</span></div>
          <div class="pg-label">52주 고점</div>
          <div class="pg-value">{{ h.high_52w | format_number }}{% if h.pct_from_52w_high >= -0.5 %} <span class="nh-badge" style="margin-left: 5px;">NEW HIGH</span>{% endif %}</div>
          <div class="pg-label">손절가</div>
          <div class="pg-value" style="color: var(--bear);">{{ h.stop_price | format_number }} 원</div>
        </div>

        <div class="portfolio-stats">
          <div class="stat"><div class="stat-label">정배열</div><div class="stat-value {{ 'up' if h.align else 'down' }}">{{ '✓' if h.align else '✗' }}</div></div>
          <div class="stat"><div class="stat-label">MA200 상승</div><div class="stat-value {{ 'up' if h.ma200_up else 'down' }}">{{ '✓' if h.ma200_up else '✗' }}</div></div>
          <div class="stat"><div class="stat-label">코어</div><div class="stat-value">{{ h.core }} / {{ h.core_max }}</div></div>
        </div>
      </div>

      <div class="portfolio-action">
        <div class="label">Action</div>
        <div class="verdict">{{ h.action_label }}</div>
        <div class="detail">매수가 +5% 기준 <strong>{{ h.add_threshold | format_number }}원</strong> {{ '미달' if h.change_pct < 5 else '도달' }} (현재 {{ h.change_pct | format_pct_signed(2) }}). 도달 시 거래량 확장 동반 여부 확인 후 1차 추매. <strong>{{ h.stop_price | format_number }}원</strong> 하회 시 전량 손절.</div>
      </div>
    </div>
    {% endfor %}

    {% set _ca_portfolio = (claude_analysis | default({})).get("portfolio") %}
    {% if _ca_portfolio %}
    <div class="claude-card">
      <div class="claude-label">🗒 Claude · 보유 종목 상태</div>
      <div class="claude-body">{{ _ca_portfolio | safe }}</div>
    </div>
    {% endif %}
  </section>

  <!-- ========== SECTION 6: MACRO CALENDAR ========== -->
  <section>
    <div class="section-header">
      <div class="section-num">06</div>
      <div class="section-title">
        <div class="eyebrow">Upcoming Events · Next 30 Days</div>
        <h2>Macro Calendar</h2>
      </div>
      {% set high_events = data.macro_calendar | selectattr("impact", "equalto", "high") | list %}
      <div class="section-meta">HIGH IMPACT · {{ high_events | length }}</div>
    </div>

    <div>
      {% for ev in data.macro_calendar %}
      {% if ev.dday is not none %}
      <div class="macro-row">
        <div class="dday{% if ev.dday >= 20 %} far{% endif %}">D−{{ ev.dday }}</div>
        <div class="macro-event">{{ ev.event_full }}</div>
        <div class="macro-date">{{ ev.date }}{% if ev.weekday %} ({{ ev.weekday }}){% endif %}</div>
        <div class="macro-impact impact-{{ ev.impact }}">{{ ev.impact | upper }} IMPACT</div>
      </div>
      {% endif %}
      {% endfor %}
    </div>

    <p style="margin-top: 16px; font-family: var(--sans); font-size: 12px; color: var(--ink-muted); line-height: 1.5; padding: 10px 14px; background: var(--bg); border-left: 3px solid var(--ink-muted);">
      {% if data.next_high_impact %}5월 초까지 매크로 이벤트 집중. {{ data.next_high_impact.event }} 전 포지션 사이징 보수적 관리, 이벤트 직전 신규 진입 자제.{% else %}당분간 주요 매크로 이벤트 없음.{% endif %}
    </p>

    {% set _ca_macro = (claude_analysis | default({})).get("macro") %}
    {% if _ca_macro %}
    <div class="claude-card">
      <div class="claude-label">🗒 Claude · 매크로 임박도</div>
      <div class="claude-body">{{ _ca_macro | safe }}</div>
    </div>
    {% endif %}
  </section>

  <!-- ========== SECTION 7: MARKET CONTEXT (NEW, 종목별 스토리 없음) ========== -->
  <section>
    <div class="section-header">
      <div class="section-num">07</div>
      <div class="section-title">
        <div class="eyebrow">Market-Wide Data Points</div>
        <h2>Market Context</h2>
      </div>
      <div class="section-meta">4 / 4</div>
    </div>

    {# Market Context v1: 수치 바인딩 중심, 문구 템플릿은 고정.
       규칙 엔진은 Phase 2 후반/3에서 도입 예정. #}
    {% set top_weekly_up = data.sector_adr003.score_jumps | selectattr("delta", "gt", 0) | list %}
    {% set top_weekly_down = data.sector_adr003.score_jumps | selectattr("delta", "lt", 0) | list %}
    {% set big_tech_down = data.tech_merged | selectattr("change_pct", "lt", 0) | sort(attribute="change_pct") %}
    {% set us_sector_down = data.us_sectors | selectattr("change_pct", "lt", 0) | sort(attribute="change_pct") %}
    <div class="context-grid">
      <div class="context-col plus-col">
        <div class="context-head">
          <h3>Catalysts</h3>
          <span class="subtag">시장 우호 데이터</span>
        </div>
        <ul class="context-list">
          {% if data.top_leader %}<li>주도 섹터 <strong>{{ data.top_leader.name }}</strong> <span class="num up">{{ data.top_leader.score | round(0) | int }}점</span> 유지{% if top_weekly_up %}, {{ top_weekly_up[0].name }} 주간 <span class="num up">{{ top_weekly_up[0].delta | format_pct_signed(1) | replace('%', '점') }}</span>{% endif %}</li>{% endif %}
          {% if kosdaq.is_20d_new_high %}<li>KOSDAQ <strong>20일 신고가</strong> <span class="num up">{{ kosdaq.change_pct | format_pct_signed(2) }}</span>, 52주 고점 대비 <span class="num down">{{ kosdaq.pct_from_52w_high | format_pct_signed(1) }}</span> 근접</li>{% endif %}
          <li>A등급 <strong>{{ data.minervini.counts.A }}종목 중 {{ data.grade_a_at_high }}종목</strong>이 52주 고점 돌파 중 (신고가 클러스터링)</li>
          {% if data.kospi_flow.institution > 0 %}<li>기관 <span class="num up">{{ data.kospi_flow.institution | format_signed_int }}억</span> 순매수{% if data.market_context.kospi_ma20_ok and data.market_context.kospi_ma60_ok and data.market_context.kospi_ma120_ok %}, KOSPI MA20/60/120 정배열 유지{% endif %}</li>{% endif %}
        </ul>
      </div>

      <div class="context-col minus-col">
        <div class="context-head">
          <h3>Headwinds</h3>
          <span class="subtag">시장 역풍 데이터</span>
        </div>
        <ul class="context-list">
          {% if data.kospi_flow.foreign < 0 %}<li>외국인 KOSPI <strong><span class="num down">{{ data.kospi_flow.foreign | format_signed_int }}억</span></strong> 순매도{% if data.kospi_flow.retail < 0 %}, 개인 <span class="num down">{{ data.kospi_flow.retail | format_signed_int }}억</span> 동반 매도{% endif %}</li>{% endif %}
          {% if big_tech_down %}<li>빅테크 약세: {% for t in big_tech_down[:3] %}{{ t.name }} <span class="num down">{{ t.change_pct | format_pct_signed(2) }}</span>{% if not loop.last %}, {% endif %}{% endfor %}</li>{% endif %}
          {% if us_sector_down %}{% set worst = us_sector_down | first %}<li>{{ worst.name }} {{ worst.ticker }} <span class="num down">{{ worst.change_pct | format_pct_signed(2) }}</span>{% if not worst.ma60 or not worst.ma120 %} + MA60/120 하향 이탈, 섹터 리더십 일부 약화{% endif %}</li>{% endif %}
          <li>USD/KRW <strong>{{ data.rates_fx.usd_krw.value | format_number(2) }}</strong> 고레벨{% if data.commodities.wti.change_pct > 0 %}, WTI <span class="num up">{{ data.commodities.wti.change_pct | format_pct_signed(2) }}</span> — 원화 자본유출·수입물가 상승 압력 병존{% endif %}</li>
        </ul>
      </div>
    </div>
  </section>

