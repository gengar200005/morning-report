<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Morning Report — 2026-04-21</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500&family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #FAFAF7;
    --bg-elevated: #FFFFFF;
    --ink: #0A0A0A;
    --ink-soft: #2C2C2C;
    --ink-muted: #5A5A5A;
    --ink-faint: #8F8F8F;
    --rule: #1A1A1A;
    --rule-soft: #E3E3DC;
    --rule-faint: #EEEEE8;

    --bull: #058C4A;
    --bull-strong: #016B38;
    --bull-bg: #D9F2E4;
    --bull-bg-soft: #EDF9F2;

    --bear: #D01E1E;
    --bear-strong: #A01414;
    --bear-bg: #FCDEDE;
    --bear-bg-soft: #FEEFEF;

    --neutral: #6B6B6B;
    --accent: #A07B3E;
    --accent-bg: #F5EDD8;
    --warn: #B8740A;
    --warn-bg: #FBF1DB;

    --serif: 'Fraunces', 'Noto Serif KR', Georgia, serif;
    --sans: 'Inter', -apple-system, 'Noto Sans KR', sans-serif;
    --mono: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--sans);
    font-size: 14px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
    padding: 40px 20px 80px;
  }

  .report {
    max-width: 1000px;
    margin: 0 auto;
    background: var(--bg-elevated);
    padding: 56px 64px;
    box-shadow: 0 2px 24px rgba(0,0,0,0.04), 0 0 0 1px var(--rule-soft);
    position: relative;
  }

  .report::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: var(--ink);
  }

  .up { color: var(--bull) !important; font-weight: 600; }
  .down { color: var(--bear) !important; font-weight: 600; }
  .flat { color: var(--neutral); }

  .pill-up {
    display: inline-block;
    padding: 2px 8px;
    background: var(--bull-bg);
    color: var(--bull-strong);
    font-family: var(--mono);
    font-weight: 700;
    font-size: 12px;
    border-radius: 2px;
  }
  .pill-down {
    display: inline-block;
    padding: 2px 8px;
    background: var(--bear-bg);
    color: var(--bear-strong);
    font-family: var(--mono);
    font-weight: 700;
    font-size: 12px;
    border-radius: 2px;
  }

  /* ========== MASTHEAD ========== */
  .masthead {
    border-bottom: 2px solid var(--ink);
    padding-bottom: 18px;
    margin-bottom: 32px;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 24px;
  }

  .masthead-left .kicker {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: 500;
    margin-bottom: 10px;
  }

  .masthead-left h1 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 48px;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 6px;
  }

  .masthead-left h1 em {
    font-style: italic;
    font-weight: 400;
    color: var(--accent);
  }

  .masthead-left .subtitle {
    font-family: var(--sans);
    font-size: 12px;
    color: var(--ink-muted);
    letter-spacing: 0.02em;
  }

  .masthead-right {
    text-align: right;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-muted);
    line-height: 1.8;
  }

  .masthead-right .date {
    font-family: var(--serif);
    font-size: 18px;
    color: var(--ink);
    font-weight: 500;
    letter-spacing: 0.02em;
    margin-bottom: 2px;
    font-style: italic;
  }

  .vol-line {
    border-top: 1px solid var(--rule-soft);
    padding-top: 6px;
    margin-top: 6px;
    font-size: 10px;
    letter-spacing: 0.1em;
  }

  /* ========== EXECUTIVE SUMMARY — TONED DOWN ========== */
  .exec {
    background: var(--ink);
    color: #F5F5F0;
    padding: 28px 36px;
    margin-bottom: 40px;
    position: relative;
  }

  .exec::before {
    content: 'EXECUTIVE SUMMARY';
    position: absolute;
    top: 14px;
    right: 18px;
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.3em;
    color: rgba(245,245,240,0.3);
  }

  .exec-rating {
    display: flex;
    gap: 8px;
    margin-bottom: 18px;
  }

  .rating-badge {
    display: inline-block;
    padding: 6px 12px;
    background: var(--accent);
    color: #0A0A0A;
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
  }

  .gate-badge {
    display: inline-block;
    padding: 6px 12px;
    background: var(--bull);
    color: #fff;
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  .exec h2 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 22px;
    line-height: 1.4;
    color: #F5F5F0;
    margin-bottom: 12px;
    letter-spacing: -0.005em;
  }

  .exec h2 strong { font-weight: 700; color: #fff; }
  .exec h2 .up { color: #4ADE8F !important; }
  .exec h2 .down { color: #FF7B7B !important; }

  .exec-facts {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid rgba(245,245,240,0.15);
  }

  .exec-fact {
    padding: 0 20px;
    border-left: 1px solid rgba(245,245,240,0.12);
  }
  .exec-fact:first-child { border-left: none; padding-left: 0; }

  .exec-fact .fact-label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.25em;
    color: var(--accent);
    margin-bottom: 6px;
    font-weight: 700;
  }

  .exec-fact .fact-text {
    font-family: var(--sans);
    font-size: 12px;
    line-height: 1.5;
    color: rgba(245,245,240,0.92);
  }

  .exec-fact .fact-text strong {
    color: #fff;
  }

  .exec-action {
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px dashed rgba(245,245,240,0.2);
    font-family: var(--sans);
    font-size: 13px;
    color: rgba(245,245,240,0.88);
    display: flex;
    gap: 10px;
    align-items: baseline;
  }

  .exec-action .tag {
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.25em;
    color: var(--accent);
    flex-shrink: 0;
  }

  /* ========== SECTIONS ========== */
  section { margin-bottom: 44px; }

  .section-header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 20px;
    margin-bottom: 22px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--ink);
    page-break-after: avoid;
  }

  .section-num {
    font-family: var(--serif);
    font-style: italic;
    font-size: 44px;
    font-weight: 300;
    color: var(--accent);
    line-height: 0.9;
  }

  .section-title h2 {
    font-family: var(--serif);
    font-size: 24px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--ink);
    line-height: 1.1;
  }

  .section-title .eyebrow {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--ink-muted);
    text-transform: uppercase;
    margin-bottom: 4px;
    font-weight: 600;
  }

  .section-meta {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--ink-faint);
    letter-spacing: 0.1em;
    text-align: right;
  }

  /* ========== INDEX GRID ========== */
  .idx-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid var(--rule-soft);
  }

  .idx-cell {
    padding: 16px 18px;
    border-right: 1px solid var(--rule-soft);
    border-bottom: 1px solid var(--rule-soft);
    position: relative;
  }
  .idx-cell:nth-child(4n) { border-right: none; }
  .idx-cell:nth-last-child(-n+4) { border-bottom: none; }

  .idx-cell.up-cell { background: linear-gradient(180deg, var(--bull-bg-soft) 0%, #fff 100%); border-left: 3px solid var(--bull); }
  .idx-cell.down-cell { background: linear-gradient(180deg, var(--bear-bg-soft) 0%, #fff 100%); border-left: 3px solid var(--bear); }

  .idx-name {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 6px;
    font-weight: 600;
  }

  .idx-value {
    font-family: var(--mono);
    font-size: 20px;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.01em;
    line-height: 1;
    margin-bottom: 5px;
  }

  .idx-change {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 700;
  }

  .idx-ma {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--ink-faint);
    margin-top: 5px;
    letter-spacing: 0.05em;
  }

  /* ========== DATA TABLE ========== */
  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--sans);
    font-size: 13px;
  }

  .data-table thead { border-bottom: 2px solid var(--ink); }

  .data-table th {
    text-align: left;
    padding: 9px 12px 9px 0;
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .data-table th.num, .data-table td.num {
    text-align: right;
    font-family: var(--mono);
    font-variant-numeric: tabular-nums;
  }

  .data-table td {
    padding: 10px 12px 10px 0;
    border-bottom: 1px solid var(--rule-faint);
    color: var(--ink-soft);
  }

  .data-table tbody tr:hover { background: var(--bg); }

  .ticker {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-faint);
    margin-left: 6px;
  }

  .name-cell strong {
    color: var(--ink);
    font-weight: 600;
  }

  /* ========== TWO COL ========== */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }

  .two-col-title {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--ink-muted);
    text-transform: uppercase;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--rule-soft);
    font-weight: 600;
  }

  /* ========== STRIP ========== */
  .strip {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0;
    padding: 16px 0;
    border-top: 1px solid var(--rule-soft);
    border-bottom: 1px solid var(--rule-soft);
  }

  .strip-item {
    padding: 0 16px;
    border-right: 1px solid var(--rule-soft);
  }
  .strip-item:last-child { border-right: none; }
  .strip-item.up-item { background: linear-gradient(180deg, var(--bull-bg-soft) 0%, transparent 100%); }
  .strip-item.down-item { background: linear-gradient(180deg, var(--bear-bg-soft) 0%, transparent 100%); }

  .strip-label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    color: var(--ink-muted);
    text-transform: uppercase;
    margin-bottom: 4px;
    font-weight: 600;
  }

  .strip-value {
    font-family: var(--mono);
    font-size: 14px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 2px;
  }

  .strip-change {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
  }

  /* ========== SECTOR CARDS ========== */
  .sector-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--rule-soft);
    border: 1px solid var(--rule-soft);
  }

  .sector-card {
    background: var(--bg-elevated);
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    min-height: 90px;
  }

  .sector-card.bull { background: linear-gradient(135deg, var(--bull-bg) 0%, #fff 70%); border-left: 3px solid var(--bull); }
  .sector-card.bear { background: linear-gradient(135deg, var(--bear-bg) 0%, #fff 70%); border-left: 3px solid var(--bear); }

  .sector-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .sector-name {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 13px;
    color: var(--ink);
  }

  .sector-score {
    font-family: var(--mono);
    font-size: 16px;
    font-weight: 700;
    color: var(--ink);
  }

  .sector-card.bull .sector-score { color: var(--bull-strong); }
  .sector-card.bear .sector-score { color: var(--bear-strong); }

  .sector-perf {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--ink-muted);
  }

  .sector-label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-top: auto;
    font-weight: 600;
  }
  .sector-card.bull .sector-label { color: var(--bull); }
  .sector-card.bear .sector-label { color: var(--bear); }

  .sector-group-title {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    font-weight: 500;
    color: var(--ink);
    margin: 20px 0 10px;
  }
  .sector-group-title:first-child { margin-top: 0; }

  .sector-group-title .count {
    font-family: var(--mono);
    font-size: 10px;
    font-style: normal;
    color: var(--ink-faint);
    margin-left: 8px;
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  /* ========== ENTRY READINESS CARDS (NEW) ========== */
  .readiness-card {
    background: var(--bg-elevated);
    border: 1px solid var(--rule-soft);
    border-left: 4px solid var(--ink);
    margin-bottom: 18px;
    overflow: hidden;
    page-break-inside: avoid;
  }

  .readiness-card.held {
    border-left-color: var(--accent);
  }

  .readiness-header {
    display: grid;
    grid-template-columns: 44px 1fr auto;
    gap: 16px;
    padding: 16px 20px 14px;
    align-items: center;
    background: linear-gradient(90deg, #FAFAF5 0%, #fff 40%);
    border-bottom: 1px dashed var(--rule-soft);
  }

  .readiness-card.held .readiness-header {
    background: linear-gradient(90deg, var(--accent-bg) 0%, #fff 40%);
  }

  .rank {
    font-family: var(--serif);
    font-style: italic;
    font-size: 36px;
    font-weight: 400;
    color: var(--accent);
    line-height: 1;
    text-align: center;
  }

  .readiness-title .name {
    font-family: var(--serif);
    font-size: 20px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 2px;
    letter-spacing: -0.01em;
  }

  .readiness-title .name .ticker {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 400;
    color: var(--ink-faint);
    margin-left: 8px;
  }

  .readiness-title .name .held-tag {
    display: inline-block;
    margin-left: 8px;
    padding: 2px 7px;
    background: var(--accent);
    color: #0A0A0A;
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.12em;
    vertical-align: middle;
  }

  .readiness-title .meta {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--ink-muted);
  }
  .readiness-title .meta span { margin-right: 12px; }

  .readiness-price {
    text-align: right;
    font-family: var(--mono);
  }
  .readiness-price .price {
    font-size: 22px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .readiness-price .stop {
    font-size: 10px;
    color: var(--bear);
    margin-top: 4px;
    font-weight: 600;
  }
  .readiness-price .rs {
    display: inline-block;
    margin-top: 6px;
    padding: 3px 10px;
    background: var(--ink);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
  }

  /* Checkpoint body */
  .readiness-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .check-col {
    padding: 16px 20px;
  }

  .check-col.auto-col {
    background: var(--bull-bg-soft);
    border-right: 1px solid var(--rule-soft);
  }

  .check-col.manual-col {
    background: var(--warn-bg);
  }

  .check-head {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 10px;
    padding-bottom: 6px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  .check-head .tag {
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.18em;
    padding: 2px 7px;
    color: #fff;
  }
  .auto-col .check-head .tag { background: var(--bull); }
  .manual-col .check-head .tag { background: var(--warn); }

  .check-head .label {
    font-family: var(--serif);
    font-style: italic;
    font-size: 13px;
    font-weight: 500;
  }
  .auto-col .check-head .label { color: var(--bull-strong); }
  .manual-col .check-head .label { color: var(--warn); }

  .check-list {
    list-style: none;
    font-family: var(--sans);
    font-size: 12px;
    line-height: 1.6;
  }

  .check-list li {
    display: grid;
    grid-template-columns: 18px 1fr auto;
    gap: 6px;
    padding: 4px 0;
    color: var(--ink-soft);
    align-items: baseline;
  }

  .check-mark {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 700;
    text-align: center;
  }
  .auto-col .check-mark { color: var(--bull); }
  .manual-col .check-mark { color: var(--warn); }

  .check-val {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-muted);
    font-weight: 600;
    margin-left: 6px;
  }

  .readiness-footer {
    padding: 12px 20px;
    background: var(--ink);
    color: rgba(245,245,240,0.9);
    font-family: var(--sans);
    font-size: 12px;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 16px;
    align-items: baseline;
  }

  .readiness-footer .verdict-tag {
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--accent);
  }

  .readiness-footer strong {
    color: #fff;
  }

  /* ========== A-GRADE TABLE ========== */
  .agrade-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
  }

  .agrade-table thead {
    background: var(--ink);
    color: #fff;
  }

  .agrade-table th {
    padding: 9px 12px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-align: left;
    color: rgba(255,255,255,0.75);
    font-weight: 600;
  }

  .agrade-table th.num { text-align: right; }
  .agrade-table tbody tr { border-bottom: 1px solid var(--rule-faint); }
  .agrade-table tbody tr:hover { background: var(--bg); }

  .agrade-table td {
    padding: 9px 12px;
    font-family: var(--sans);
    color: var(--ink-soft);
  }

  .agrade-table td.num {
    font-family: var(--mono);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .agrade-table td.name {
    font-weight: 700;
    color: var(--ink);
  }

  .rs-bar {
    display: inline-block;
    min-width: 40px;
    text-align: center;
    padding: 2px 7px;
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    border-radius: 2px;
  }

  .rs-90 { background: var(--bull); color: #fff; }
  .rs-80 { background: var(--bull-bg); color: var(--bull-strong); }
  .rs-70 { background: var(--rule-soft); color: var(--ink-soft); }

  .nh-badge {
    display: inline-block;
    padding: 2px 6px;
    background: var(--accent);
    color: #0A0A0A;
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  /* ========== PORTFOLIO ========== */
  .portfolio-main {
    background: linear-gradient(135deg, var(--accent-bg) 0%, #fff 50%);
    padding: 28px 32px;
    border: 1px solid var(--rule-soft);
    border-top: 4px solid var(--accent);
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 36px;
    align-items: start;
  }

  .portfolio-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px dashed var(--ink-faint);
  }

  .portfolio-name {
    font-family: var(--serif);
    font-size: 24px;
    font-weight: 500;
  }

  .portfolio-status {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    padding: 5px 12px;
    background: var(--accent);
    color: #0A0A0A;
    letter-spacing: 0.15em;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 10px 24px;
    margin-bottom: 18px;
  }

  .pg-label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--ink-muted);
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  .pg-value {
    font-family: var(--mono);
    font-size: 14px;
    color: var(--ink);
    font-weight: 600;
  }
  .pg-value.big {
    font-size: 20px;
    font-weight: 700;
  }

  .portfolio-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    padding-top: 14px;
    border-top: 1px solid var(--rule-soft);
  }

  .stat {
    padding-right: 14px;
    border-right: 1px solid var(--rule-soft);
  }
  .stat:last-child { border-right: none; padding-right: 0; padding-left: 14px; }
  .stat:nth-child(2) { padding-left: 14px; }

  .stat-label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.2em;
    color: var(--ink-muted);
    text-transform: uppercase;
    margin-bottom: 3px;
    font-weight: 600;
  }
  .stat-value {
    font-family: var(--mono);
    font-size: 15px;
    font-weight: 700;
    color: var(--ink);
  }

  .portfolio-action {
    padding: 20px;
    background: var(--ink);
    color: #F5F5F0;
  }
  .portfolio-action .label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.25em;
    color: var(--accent);
    margin-bottom: 6px;
    font-weight: 700;
  }
  .portfolio-action .verdict {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 500;
    margin-bottom: 8px;
  }
  .portfolio-action .detail {
    font-family: var(--sans);
    font-size: 12px;
    line-height: 1.55;
    color: rgba(245,245,240,0.85);
  }
  .portfolio-action .detail strong { color: #fff; }

  /* ========== MACRO CALENDAR ========== */
  .macro-row {
    display: grid;
    grid-template-columns: 80px 1fr 140px 110px;
    gap: 16px;
    padding: 12px 0;
    border-bottom: 1px solid var(--rule-faint);
    align-items: center;
  }
  .macro-row:last-child { border-bottom: none; }

  .dday {
    font-family: var(--serif);
    font-style: italic;
    font-size: 22px;
    font-weight: 500;
    color: var(--bear);
  }
  .dday.far { color: var(--ink-muted); }

  .macro-event {
    font-family: var(--serif);
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
  }

  .macro-date {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-muted);
  }

  .macro-impact {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    padding: 4px 9px;
    text-align: center;
    font-weight: 700;
  }
  .impact-high { background: var(--bear-bg); color: var(--bear-strong); }

  /* ========== MARKET CONTEXT ========== */
  .context-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--rule-soft);
  }

  .context-col {
    padding: 24px 28px;
  }

  .context-col.plus-col {
    background: linear-gradient(180deg, var(--bull-bg) 0%, var(--bull-bg-soft) 100%);
    border-right: 1px solid var(--rule-soft);
  }
  .context-col.minus-col {
    background: linear-gradient(180deg, var(--bear-bg) 0%, var(--bear-bg-soft) 100%);
  }

  .context-head {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 14px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--ink);
  }

  .context-head h3 {
    font-family: var(--serif);
    font-style: italic;
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .plus-col h3 { color: var(--bull-strong); }
  .minus-col h3 { color: var(--bear-strong); }

  .context-head .subtag {
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--ink-muted);
  }

  .context-list {
    list-style: none;
  }
  .context-list li {
    font-family: var(--sans);
    font-size: 12px;
    line-height: 1.55;
    color: var(--ink-soft);
    padding: 8px 0 8px 16px;
    position: relative;
    border-bottom: 1px solid rgba(0,0,0,0.04);
  }
  .context-list li:last-child { border-bottom: none; }

  .context-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 15px;
    width: 7px;
    height: 2px;
  }
  .plus-col .context-list li::before { background: var(--bull); }
  .minus-col .context-list li::before { background: var(--bear); }

  .context-list strong { color: var(--ink); }
  .context-list .num { font-family: var(--mono); font-weight: 700; }

  /* ========== FOOTER ========== */
  footer {
    margin-top: 56px;
    padding-top: 20px;
    border-top: 2px solid var(--ink);
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 20px;
    align-items: end;
  }

  .footer-brand {
    font-family: var(--serif);
    font-style: italic;
    font-size: 14px;
    color: var(--ink-muted);
  }
  .footer-brand strong {
    color: var(--ink);
    font-style: normal;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .footer-meta {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--ink-faint);
    letter-spacing: 0.1em;
    text-align: right;
  }

  .disclosures {
    margin-top: 28px;
    padding: 18px 22px;
    background: var(--bg);
    border-left: 3px solid var(--ink-muted);
    font-size: 11px;
    color: var(--ink-muted);
    line-height: 1.55;
  }
  .disclosures strong { color: var(--ink-soft); }
  .disclosures p { margin-bottom: 8px; }
  .disclosures p:last-child { margin-bottom: 0; }

  hr.decorative {
    border: none;
    text-align: center;
    margin: 32px 0;
    color: var(--ink-faint);
  }
  hr.decorative::after {
    content: '§ § §';
    font-family: var(--serif);
    font-size: 13px;
    letter-spacing: 1em;
  }

  /* ========== CLAUDE ANALYSIS CARDS (v3.0) ========== */
  .claude-card {
    margin-top: 20px;
    padding: 14px 16px 14px 18px;
    background: var(--accent-bg);
    border-left: 3px solid var(--accent);
    font-family: var(--sans);
    font-size: 12px;
    color: var(--ink-soft);
    line-height: 1.6;
    page-break-inside: avoid;
  }
  .claude-card .claude-label {
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.25em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .claude-card .claude-body {
    color: var(--ink-soft);
  }
  .claude-card .claude-body p {
    margin: 0 0 6px 0;
  }
  .claude-card .claude-body p:last-child { margin-bottom: 0; }
  .claude-card .claude-body ul {
    list-style: none;
    padding: 0;
    margin: 4px 0 0 0;
  }
  .claude-card .claude-body li {
    padding: 2px 0 2px 14px;
    position: relative;
  }
  .claude-card .claude-body li::before {
    content: '·';
    position: absolute;
    left: 4px;
    color: var(--accent);
    font-weight: 700;
  }
  .claude-card strong { color: var(--ink); }

  .claude-card.alert {
    background: var(--bear-bg-soft);
    border-left-color: var(--bear);
  }
  .claude-card.alert .claude-label { color: var(--bear); }
  .claude-card.alert .claude-body li::before { color: var(--bear); }

  /* PDF 페이지 분할 제어 — Chrome headless (render_pdf.py).
     구문법(page-break-*)과 신문법(break-*) 병기. */

  /* 작은 단위: 절대 찢지 말 것 */
  table, tr, th, td,
  .check-col, .check-list,
  .macro-row, .strip-item, .idx-cell,
  .claude-card, .two-col {
    page-break-inside: avoid;
    break-inside: avoid;
  }

  /* 종목/섹터 카드: 한 카드는 한 페이지에 */
  .readiness-card,
  .portfolio-main,
  .sector-card,
  .context-col {
    page-break-inside: avoid;
    break-inside: avoid;
  }

  /* 섹션 헤더는 뒤따르는 본문과 붙여서 */
  h1, h2, h3,
  .section-header,
  .readiness-header,
  .two-col-title,
  .context-head {
    page-break-after: avoid;
    break-after: avoid;
  }

  .readiness-footer {
    page-break-before: avoid;
    break-before: avoid;
  }

  @media print {
    body { padding: 0; background: #fff; }
    .report { box-shadow: none; padding: 36px; }
  }
</style>
</head>
<body>

<div class="report">

  <!-- ========== MASTHEAD ========== -->
  <header class="masthead">
    <div class="masthead-left">
      <div class="kicker">Daily Market Brief</div>
      <h1>Morning <em>Report</em></h1>
      <div class="subtitle">Minervini trend-following · 국내 주식 스크리닝</div>
    </div>
    <div class="masthead-right">
      <div class="date">{{ data.date | format_date_long }}</div>
      <div>06:00 KST</div>
      <div class="vol-line">v6.2</div>
    </div>
  </header>

  <!-- ========== EXECUTIVE SUMMARY — TONED DOWN ========== -->
  {% set kospi = data.kr_indices | selectattr("name", "equalto", "KOSPI") | first %}
  {% set kosdaq = data.kr_indices | selectattr("name", "equalto", "KOSDAQ") | first %}
  {% set holding = data.holdings[0] if data.holdings else None %}
  <div class="exec">
    <div class="exec-rating">
      <span class="rating-badge">BUY-WATCH</span>
      <span class="gate-badge">{{ '✓' if data.market_context.vix_ok and data.market_context.kospi_ma60_ok else '✗' }} 시장 게이트 {{ '통과' if data.market_context.vix_ok and data.market_context.kospi_ma60_ok else '미달' }}</span>
    </div>
    <h2>
      KOSPI <span class="{{ 'up' if kospi.change_pct >= 0 else 'down' }}">{{ data.kospi_state }}</span> · KOSDAQ <span class="{{ 'up' if kosdaq.change_pct >= 0 or kosdaq.is_20d_new_high else 'down' }}">{{ data.kosdaq_state }}</span>. A등급 <strong>{{ data.minervini.counts.A }}종목</strong>.
    </h2>

    <div class="exec-facts">
      <div class="exec-fact">
        <div class="fact-label">MARKET</div>
        <div class="fact-text">미국 3대 지수 <strong>{{ data.us_state }}</strong>, VIX <strong>{{ data.vix.value }}</strong> {{ data.vix.status }}권.{% if kosdaq.is_20d_new_high %} 코스닥 20일 신고가 <strong>{{ kosdaq.trend_20d | format_pct_signed(1) }}</strong>.{% else %} 코스닥 <strong>{{ kosdaq.change_pct | format_pct_signed(2) }}</strong>.{% endif %}</div>
      </div>
      <div class="exec-fact">
        <div class="fact-label">SCREENER</div>
        <div class="fact-text">A등급 <strong>{{ data.minervini.counts.A }}종목</strong>{% if data.top_leader %}, 주도 섹터 {{ data.top_leader.name }} <strong>{{ data.top_leader.score | round(0) | int }}점</strong>{% endif %}. B/C/D {{ data.minervini.bcd_total }}종목.</div>
      </div>
      <div class="exec-fact">
        <div class="fact-label">PORTFOLIO</div>
        {% if holding %}
        <div class="fact-text">{{ holding.name }} <span class="{{ 'up' if holding.change_pct >= 0 else 'down' }}">{{ holding.change_pct | format_pct_signed(2) }}</span>, 추매 기준(+5%) <strong>{{ '미달' if holding.change_pct < 5 else '도달' }}</strong>. HOLD.</div>
        {% else %}
        <div class="fact-text">보유 종목 없음.</div>
        {% endif %}
      </div>
    </div>

    {% if holding and data.next_high_impact %}
    <div class="exec-action">
      <span class="tag">ACTION</span>
      <span>{{ holding.name }} <strong>{{ holding.add_threshold | format_number }}원</strong> {% if holding.change_pct < 5 %}도달 전 관망{% else %}돌파 · 거래량 수동 확인{% endif %}. <strong>{{ data.next_high_impact.event }} D−{{ data.next_high_impact.dday }}</strong> 이전 신규 진입 보수적.</span>
    </div>
    {% endif %}
  </div>

  {% set _ca_alert = (claude_analysis | default({})).get("alert") %}
  {% if _ca_alert %}
  <div class="claude-card alert">
    <div class="claude-label">🗒 Claude · 오늘의 주의사항</div>
    <div class="claude-body">{{ _ca_alert | safe }}</div>
  </div>
  {% endif %}

  <!-- ========== SECTION 1: US MARKETS ========== -->
  <section>
    <div class="section-header">
      <div class="section-num">01</div>
      <div class="section-title">
        <div class="eyebrow">New York · Prior Close</div>
        <h2>U.S. Markets</h2>
      </div>
      <div class="section-meta">04/20 CLOSE</div>
    </div>

    <div class="idx-grid">
      {% for idx in data.us_indices %}
      {% set dir = 'up' if idx.change_pct >= 0 else 'down' %}
      <div class="idx-cell {{ dir }}-cell">
        <div class="idx-name">{% if idx.name == 'S&P 500' %}S&amp;P 500{% else %}{{ idx.name }}{% endif %}</div>
        <div class="idx-value">{{ idx.value | format_number(2) }}</div>
        <div class="idx-change {{ dir }}">{{ idx.change_pct | format_change_arrow }} {{ idx.change_pct | format_pct_signed(2) }}</div>
        <div class="idx-ma">MA 20 / 60 / 120 {{ '✓' if idx.ma20 and idx.ma60 and idx.ma120 else '⚠' }}</div>
      </div>
      {% endfor %}
    </div>

    <div class="strip" style="margin-top: 20px;">
      <div class="strip-item">
        <div class="strip-label">VIX</div>
        <div class="strip-value">{{ data.vix.value }}</div>
        <div class="strip-change flat">{{ data.vix.status }}</div>
      </div>
      {% set t10 = data.rates_fx.us10y %}
      <div class="strip-item {{ 'up' if t10.change_pct >= 0 else 'down' }}-item">
        <div class="strip-label">US 10Y</div>
        <div class="strip-value">{{ t10.value }}</div>
        <div class="strip-change {{ 'up' if t10.change_pct >= 0 else 'down' }}">{{ t10.change_pct | format_change_arrow }} {{ t10.change_pct | format_pct_signed(2) | replace('%', '') }}</div>
      </div>
      {% set dxy = data.rates_fx.dxy %}
      <div class="strip-item {{ 'up' if dxy.change_pct >= 0 else 'down' }}-item">
        <div class="strip-label">DXY</div>
        <div class="strip-value">{{ dxy.value }}</div>
        <div class="strip-change {{ 'up' if dxy.change_pct >= 0 else 'down' }}">{{ dxy.change_pct | format_change_arrow }} {{ dxy.change_pct | format_pct_signed(2) | replace('%', '') }}</div>
      </div>
      {% set fx = data.rates_fx.usd_krw %}
      <div class="strip-item {{ 'up' if fx.change_pct >= 0 else 'down' }}-item">
        <div class="strip-label">USD/KRW</div>
        <div class="strip-value">{{ fx.value | format_number(2) }}</div>
        <div class="strip-change {{ 'up' if fx.change_pct >= 0 else 'down' }}">{{ fx.change_pct | format_change_arrow }} {{ fx.change_pct | format_pct_signed(2) | replace('%', '') }}</div>
      </div>
      {% set wti = data.commodities.wti %}
      <div class="strip-item {{ 'up' if wti.change_pct >= 0 else 'down' }}-item">
        <div class="strip-label">WTI</div>
        <div class="strip-value">{{ wti.value }}</div>
        <div class="strip-change {{ 'up' if wti.change_pct >= 0 else 'down' }}">{{ wti.change_pct | format_change_arrow }} {{ wti.change_pct | format_pct_signed(2) }}</div>
      </div>
      {% set gold = data.commodities.gold %}
      <div class="strip-item {{ 'up' if gold.change_pct >= 0 else 'down' }}-item">
        <div class="strip-label">GOLD</div>
        <div class="strip-value">{{ gold.value | format_number(0) }}</div>
        <div class="strip-change {{ 'up' if gold.change_pct >= 0 else 'down' }}">{{ gold.change_pct | format_change_arrow }} {{ gold.change_pct | format_pct_signed(2) }}</div>
      </div>
    </div>

    <div class="two-col" style="margin-top: 28px;">
      <div>
        <div class="two-col-title">US Sectors</div>
        <table class="data-table">
          <thead>
            <tr><th>Sector</th><th class="num">Change</th><th class="num">MA</th></tr>
          </thead>
          <tbody>
            {% for s in data.us_sectors %}
            {% set pill = 'pill-up' if s.change_pct >= 0 else 'pill-down' %}
            <tr><td class="name-cell"><strong>{{ s.name }}</strong> <span class="ticker">{{ s.ticker }}</span></td><td class="num"><span class="{{ pill }}">{{ s.change_pct | format_change_arrow }} {{ s.change_pct | format_pct_signed(2) }}</span></td><td class="num">{{ '✓' if s.ma20 else '✗' }}/{{ '✓' if s.ma60 else '✗' }}/{{ '✓' if s.ma120 else '✗' }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      <div>
        <div class="two-col-title">Big Tech &amp; Semi</div>
        <table class="data-table">
          <thead>
            <tr><th>Name</th><th class="num">Close</th><th class="num">Chg</th></tr>
          </thead>
          <tbody>
            {% for t in data.tech_merged %}
            {% set pill = 'pill-up' if t.change_pct >= 0 else 'pill-down' %}
            <tr><td class="name-cell"><strong>{% if t.name == '마이크로소프트' %}MS{% else %}{{ t.name }}{% endif %}</strong></td><td class="num">{{ t.value | format_number(2) }}</td><td class="num"><span class="{{ pill }}">{{ t.change_pct | format_change_arrow }} {{ t.change_pct | format_pct_signed(2) }}</span></td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ========== SECTION 2: KOREA MARKETS ========== -->
  <section>
    <div class="section-header">
      <div class="section-num">02</div>
      <div class="section-title">
        <div class="eyebrow">Seoul · Prior Close</div>
        <h2>Korea Markets</h2>
      </div>
      <div class="section-meta">04/20 CLOSE</div>
    </div>

    <div class="idx-grid" style="grid-template-columns: 1fr 1fr;">
      {% for idx in data.kr_indices %}
      {% set dir = 'up' if idx.change_pct >= 0 else 'down' %}
      <div class="idx-cell {{ dir }}-cell">
        <div class="idx-name">{{ idx.name }}</div>
        <div class="idx-value">{{ idx.value | format_number(2) }}</div>
        <div class="idx-change {{ dir }}">{{ idx.change_pct | format_change_arrow }} {{ idx.change_pct | format_pct_signed(2) }}{% if idx.is_20d_new_high %} <span class="nh-badge" style="margin-left: 8px;">20D NH</span>{% endif %}</div>
        <div class="idx-ma">5D {{ idx.trend_5d | format_pct_signed(1) }} · 20D {{ idx.trend_20d | format_pct_signed(1) }} · 52W HIGH {{ idx.pct_from_52w_high | format_pct_signed(1) }}</div>
      </div>
      {% endfor %}
    </div>

    <div class="two-col" style="margin-top: 24px;">
      <div>
        <div class="two-col-title">KOSPI Flow{% if data.kospi_flow.basis_md %} · {{ data.kospi_flow.basis_md }}{% endif %} (억원)</div>
        <table class="data-table">
          <tbody>
            {% set flow = data.kospi_flow %}
            <tr><td class="name-cell"><strong>외국인</strong></td><td class="num"><span class="{{ 'pill-up' if flow.foreign >= 0 else 'pill-down' }}" style="font-size: 13px; padding: 3px 10px;">{{ flow.foreign | format_signed_int }}</span></td></tr>
            <tr><td class="name-cell"><strong>기관</strong></td><td class="num"><span class="{{ 'pill-up' if flow.institution >= 0 else 'pill-down' }}" style="font-size: 13px; padding: 3px 10px;">{{ flow.institution | format_signed_int }}</span></td></tr>
            <tr><td class="name-cell"><strong>개인</strong></td><td class="num"><span class="{{ 'pill-up' if flow.retail >= 0 else 'pill-down' }}" style="font-size: 13px; padding: 3px 10px;">{{ flow.retail | format_signed_int }}</span></td></tr>
          </tbody>
        </table>
      </div>
      <div>
        <div class="two-col-title">Market Gate · Minervini</div>
        <div style="padding: 4px 0;">
          {% set ctx = data.market_context %}
          <div style="display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px dashed var(--rule-soft);">
            <span>VIX ≤ 35</span>
            <span class="{{ 'up' if ctx.vix_ok else 'down' }}" style="font-family: var(--mono);">{{ '✓' if ctx.vix_ok else '✗' }} {{ ctx.vix }}</span>
          </div>
          <div style="display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px dashed var(--rule-soft);">
            <span>KOSPI &gt; MA60</span>
            <span class="{{ 'up' if ctx.kospi_ma60_ok else 'down' }}" style="font-family: var(--mono);">{{ '✓' if ctx.kospi_ma60_ok else '✗' }} {{ data.kospi_above_ma60_pct | format_pct_signed(1) }}</span>
          </div>
          <div style="display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px dashed var(--rule-soft);">
            <span>KOSPI MA20/60/120</span>
            {% set kospi_aligned = ctx.kospi_ma20_ok and ctx.kospi_ma60_ok and ctx.kospi_ma120_ok %}
            <span class="{{ 'up' if kospi_aligned else 'down' }}" style="font-family: var(--mono);">{{ '✓ 정배열' if kospi_aligned else '✗ 미정렬' }}</span>
          </div>
          <div style="display: flex; justify-content: space-between; padding: 8px 0;">
            <span>KOSDAQ MA20/60/120</span>
            {% set kosdaq_aligned = ctx.kosdaq_ma20_ok and ctx.kosdaq_ma60_ok and ctx.kosdaq_ma120_ok %}
            <span class="{{ 'up' if kosdaq_aligned else 'down' }}" style="font-family: var(--mono);">{{ '✓ 정배열' if kosdaq_aligned else '✗ 미정렬' }}</span>
          </div>
        </div>
      </div>
    </div>

    {% set _ca_gate_flow = (claude_analysis | default({})).get("gate_flow") %}
    {% if _ca_gate_flow %}
    <div class="claude-card">
      <div class="claude-label">🗒 Claude · 시장 게이트 · 수급</div>
      <div class="claude-body">{{ _ca_gate_flow | safe }}</div>
    </div>
    {% endif %}
  </section>

  <!-- ========== SECTION 3: SECTOR LEADERSHIP ========== -->
  <section>
    <div class="section-header">
      <div class="section-num">03</div>
      <div class="section-title">
        <div class="eyebrow">ADR-003 · IBD 6M + Breadth MA50</div>
        <h2>Sector Leadership</h2>
      </div>
      <div class="section-meta">11 Sectors · KOSPI200</div>
    </div>

    <div class="sector-group-title">Leaders <span class="count">≥ 75</span></div>
    <div class="sector-grid" style="grid-template-columns: 1fr;">
      {% for sec in data.sector_adr003.leaders %}
      <div class="sector-card bull">
        <div class="sector-head">
          <div class="sector-name">{{ sec.name }}</div>
          <div class="sector-score">{{ sec.score | format_number(1) }}</div>
        </div>
        <div class="sector-perf">{{ sec.n_stocks }}종목{% if sec.breadth_pct is not none %} · breadth <span class="{{ 'up' if sec.breadth_pct >= 0.5 else 'down' }}">{{ (sec.breadth_pct * 100) | round(0) | int }}%</span>{% endif %}</div>
        <div class="sector-label">● Dominant leader</div>
      </div>
      {% endfor %}
    </div>

    <div class="sector-group-title">Strong <span class="count">60–74</span></div>
    <div class="sector-grid">
      {% for sec in data.sector_adr003.strong %}
      <div class="sector-card bull"><div class="sector-head"><div class="sector-name">{{ sec.name }}</div><div class="sector-score">{{ sec.score | format_number(1) }}</div></div><div class="sector-perf">{{ sec.n_stocks }}종목{% if sec.breadth_pct is not none %} · breadth <span class="{{ 'up' if sec.breadth_pct >= 0.5 else 'down' }}">{{ (sec.breadth_pct * 100) | round(0) | int }}%</span>{% endif %}</div><div class="sector-label">● Strong</div></div>
      {% endfor %}
    </div>

    <div class="sector-group-title">Neutral <span class="count">40–59</span></div>
    <div class="sector-grid">
      {% for sec in data.sector_adr003.neutral %}
      <div class="sector-card"><div class="sector-head"><div class="sector-name">{{ sec.name }}</div><div class="sector-score">{{ sec.score | format_number(1) }}</div></div><div class="sector-perf">{{ sec.n_stocks }}종목{% if sec.breadth_pct is not none %} · breadth {{ (sec.breadth_pct * 100) | round(0) | int }}%{% endif %}</div><div class="sector-label">〰 Sideways</div></div>
      {% endfor %}
    </div>

    <div class="sector-group-title">Weak <span class="count">&lt; 40</span></div>
    <div class="sector-grid">
      {% for sec in data.sector_adr003.weak %}
      <div class="sector-card bear"><div class="sector-head"><div class="sector-name">{{ sec.name }}</div><div class="sector-score">{{ sec.score | format_number(1) }}</div></div><div class="sector-perf">{{ sec.n_stocks }}종목{% if sec.breadth_pct is not none %} · breadth {{ (sec.breadth_pct * 100) | round(0) | int }}%{% endif %}</div><div class="sector-label">Weakening</div></div>
      {% endfor %}
